# Optional Qwen Cloud planner configuration.
# Leave blank to use ForgePilot's local deterministic fallback.
# Do not commit .env.local or real secrets.
# QWEN_BASE_URL should point to the OpenAI-compatible Qwen/Alibaba endpoint.
# QWEN_MODEL should match a model enabled in your Qwen Cloud account.
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=

# Optional inbound webhook shared-secret header.
# If set, POST /api/webhooks/forgepilot requires x-forgepilot-secret.
FORGEPILOT_WEBHOOK_SECRET=
